{
  "version": "0.1.0",
  "appName": "Research Telemetry Portal",
  "description": "A permissioned graph for a research website, private dashboard, device ingest path, telemetry tables, and AI-agent access rules.",
  "nodes": [
    {
      "id": "public_site",
      "name": "Public Site",
      "type": "website",
      "description": "Public website and entry point.",
      "x": 64,
      "y": 116,
      "fields": [
        { "name": "pages", "type": "static_html", "description": "public pages" },
        { "name": "portal", "type": "route", "description": "dashboard entry" },
        { "name": "request", "type": "route", "description": "request form entry" }
      ]
    },
    {
      "id": "research_portal",
      "name": "Research Portal",
      "type": "website",
      "description": "Authenticated dashboard for time-series telemetry.",
      "x": 64,
      "y": 350,
      "fields": [
        { "name": "session", "type": "auth_session", "description": "signed-in user session" },
        { "name": "graph", "type": "view", "description": "chart and export UI" }
      ]
    },
    {
      "id": "request_form",
      "name": "Request Form",
      "type": "website",
      "description": "Public intake form for access or project requests.",
      "x": 64,
      "y": 595,
      "fields": [
        { "name": "name", "type": "text", "description": "requester name" },
        { "name": "email", "type": "text", "description": "requester email" },
        { "name": "message", "type": "text", "description": "request detail" }
      ]
    },
    {
      "id": "auth",
      "name": "Auth",
      "type": "auth",
      "description": "Human account and session identity.",
      "x": 350,
      "y": 105,
      "fields": [
        { "name": "users", "type": "identity", "description": "human users" },
        { "name": "jwt", "type": "token", "description": "signed session claims" }
      ]
    },
    {
      "id": "project_members",
      "name": "project_members",
      "type": "table",
      "description": "Permission join table for project access.",
      "x": 350,
      "y": 335,
      "fields": [
        { "name": "project_id", "type": "uuid not null", "description": "project reference" },
        { "name": "user_id", "type": "uuid not null", "description": "auth user reference" },
        { "name": "role", "type": "text not null", "description": "owner, admin, researcher, viewer" }
      ]
    },
    {
      "id": "project_invites",
      "name": "project_invites",
      "type": "table",
      "description": "One-time invite records for account access.",
      "x": 350,
      "y": 575,
      "fields": [
        { "name": "token_hash", "type": "text not null unique", "description": "hashed invite token" },
        { "name": "email", "type": "text not null", "description": "invited email" },
        { "name": "role", "type": "text not null", "description": "role granted on accept" },
        { "name": "expires_at", "type": "timestamptz not null", "description": "expiration time" }
      ]
    },
    {
      "id": "projects",
      "name": "projects",
      "type": "table",
      "description": "Project and data boundary.",
      "x": 655,
      "y": 180,
      "fields": [
        { "name": "id", "type": "uuid primary key", "description": "project id" },
        { "name": "organization_id", "type": "uuid not null", "description": "owning organization" },
        { "name": "name", "type": "text not null", "description": "project name" }
      ]
    },
    {
      "id": "devices",
      "name": "devices",
      "type": "table",
      "description": "Device registry.",
      "x": 940,
      "y": 105,
      "fields": [
        { "name": "id", "type": "text primary key", "description": "device id" },
        { "name": "project_id", "type": "uuid not null", "description": "project boundary" },
        { "name": "last_seen_at", "type": "timestamptz", "description": "device freshness" }
      ]
    },
    {
      "id": "device_secrets",
      "name": "device_secrets",
      "type": "secret",
      "description": "Hashed device token storage.",
      "x": 940,
      "y": 325,
      "fields": [
        { "name": "device_id", "type": "text primary key", "description": "device reference" },
        { "name": "token_hash", "type": "text not null", "description": "hashed device token" },
        { "name": "revoked_at", "type": "timestamptz", "description": "token rotation marker" }
      ]
    },
    {
      "id": "device_ingest",
      "name": "device_ingest",
      "type": "function",
      "description": "Controlled write path from device to database.",
      "x": 940,
      "y": 548,
      "fields": [
        { "name": "device_token", "type": "secret_input", "description": "raw token checked against hash" },
        { "name": "payload", "type": "jsonb", "description": "device events" }
      ]
    },
    {
      "id": "telemetry_readings",
      "name": "telemetry_readings",
      "type": "table",
      "description": "Time-series measurement data.",
      "x": 1225,
      "y": 318,
      "fields": [
        { "name": "event_id", "type": "text not null unique", "description": "dedupe key" },
        { "name": "project_id", "type": "uuid not null", "description": "project boundary" },
        { "name": "device_id", "type": "text not null", "description": "source device" },
        { "name": "measurement_value", "type": "double precision", "description": "calibrated value" },
        { "name": "device_recorded_at", "type": "timestamptz not null", "description": "device timestamp" }
      ]
    },
    {
      "id": "request_intake",
      "name": "request_intake",
      "type": "table",
      "description": "Private business or access request table.",
      "x": 655,
      "y": 650,
      "fields": [
        { "name": "name", "type": "text not null", "description": "requester name" },
        { "name": "email", "type": "text not null", "description": "requester email" },
        { "name": "notification_status", "type": "text", "description": "delivery status" }
      ]
    },
    {
      "id": "submit_request",
      "name": "submit-request",
      "type": "function",
      "description": "Saves requests and sends notification.",
      "x": 655,
      "y": 805,
      "fields": [
        { "name": "payload", "type": "json", "description": "form payload" },
        { "name": "message_id", "type": "text", "description": "notification id" }
      ]
    },
    {
      "id": "analysis_agent",
      "name": "Analysis Agent",
      "type": "agent",
      "description": "AI agent with limited access to safe measurement fields.",
      "x": 1225,
      "y": 585,
      "fields": [
        { "name": "identity", "type": "agent", "description": "non-human actor" },
        { "name": "scope", "type": "field_limited", "description": "reads selected fields only" }
      ]
    },
    {
      "id": "coding_agent",
      "name": "Coding Agent",
      "type": "agent",
      "description": "Agent that can inspect schema but not production rows.",
      "x": 1225,
      "y": 795,
      "fields": [
        { "name": "identity", "type": "agent", "description": "non-human actor" },
        { "name": "scope", "type": "schema_only", "description": "no row access" }
      ]
    }
  ],
  "edges": [
    { "id": "edge_public_portal", "from": "public_site", "to": "research_portal", "type": "opens", "description": "public site opens the dashboard" },
    { "id": "edge_public_request", "from": "public_site", "to": "request_form", "type": "opens", "description": "public site opens request form" },
    { "id": "edge_portal_auth", "from": "research_portal", "to": "auth", "type": "authenticates", "description": "portal uses signed session" },
    { "id": "edge_auth_members", "from": "auth", "to": "project_members", "type": "checks", "description": "access checks signed-in user" },
    { "id": "edge_members_projects", "from": "project_members", "to": "projects", "type": "allows", "description": "membership grants project visibility" },
    { "id": "edge_projects_devices", "from": "projects", "to": "devices", "type": "owns", "description": "project owns devices" },
    { "id": "edge_devices_ingest", "from": "devices", "to": "device_ingest", "type": "publishes", "description": "publisher sends telemetry" },
    { "id": "edge_secrets_ingest", "from": "device_secrets", "to": "device_ingest", "type": "validates", "description": "ingest validates hashed token" },
    { "id": "edge_ingest_readings", "from": "device_ingest", "to": "telemetry_readings", "type": "writes", "description": "ingest inserts telemetry rows" },
    { "id": "edge_portal_readings", "from": "research_portal", "to": "telemetry_readings", "type": "reads", "description": "portal renders rows" },
    { "id": "edge_request_submit", "from": "request_form", "to": "submit_request", "type": "writes", "description": "form calls request function" },
    { "id": "edge_submit_intake", "from": "submit_request", "to": "request_intake", "type": "writes", "description": "function writes private request" },
    { "id": "edge_agent_readings", "from": "analysis_agent", "to": "telemetry_readings", "type": "reads", "description": "agent reads allowed fields only" },
    { "id": "edge_coding_inspect", "from": "coding_agent", "to": "telemetry_readings", "type": "inspect", "description": "agent inspects schema only" }
  ],
  "policies": [
    {
      "id": "policy_member_read_project_rows",
      "principal_type": "human",
      "principal_id": "project_member",
      "resource_type": "table",
      "resource_id": "telemetry_readings",
      "action": "read",
      "effect": "allow",
      "conditions": "user is a member of row.project_id"
    },
    {
      "id": "policy_agent_read_measurements",
      "principal_type": "agent",
      "principal_id": "analysis_agent",
      "resource_type": "field",
      "resource_id": "telemetry_readings",
      "action": "read",
      "effect": "allow",
      "conditions": "fields: project_id, measurement_value, device_recorded_at only"
    },
    {
      "id": "policy_coding_agent_no_rows",
      "principal_type": "agent",
      "principal_id": "coding_agent",
      "resource_type": "table",
      "resource_id": "telemetry_readings",
      "action": "read",
      "effect": "deny",
      "conditions": "schema inspection allowed; production rows denied"
    },
    {
      "id": "policy_device_execute_ingest",
      "principal_type": "device",
      "principal_id": "devices",
      "resource_type": "function",
      "resource_id": "device_ingest",
      "action": "execute",
      "effect": "allow",
      "conditions": "valid device token hash"
    }
  ],
  "agents": [
    {
      "id": "analysis_agent",
      "name": "Analysis Agent",
      "can": [
        {
          "action": "read_rows",
          "resource": "telemetry_readings",
          "fields": ["project_id", "measurement_value", "device_recorded_at"],
          "where": "project_id = allowed_project_id"
        }
      ]
    },
    {
      "id": "coding_agent",
      "name": "Coding Agent",
      "can": [
        {
          "action": "inspect_schema",
          "resource": "public.*"
        },
        {
          "action": "read_rows",
          "resource": "telemetry_readings",
          "condition": "deny"
        }
      ]
    }
  ]
}
