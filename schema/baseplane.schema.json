{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baseplane.dev/schema/baseplane.schema.json",
  "title": "Baseplane Graph",
  "type": "object",
  "required": ["version", "appName", "nodes", "edges", "policies"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "appName": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "policies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policy"
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent"
      }
    }
  },
  "$defs": {
    "field": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "node": {
      "type": "object",
      "required": ["id", "name", "type", "x", "y"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_:-]*$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["table", "auth", "function", "device", "secret", "website", "agent", "deployment"]
        },
        "description": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["id", "from", "to", "type"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "type": "string",
          "minLength": 1
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": ["id", "principal_type", "principal_id", "resource_type", "resource_id", "action", "effect"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "principal_type": {
          "enum": ["human", "organization", "device", "service", "agent"]
        },
        "principal_id": {
          "type": "string",
          "minLength": 1
        },
        "resource_type": {
          "enum": ["table", "field", "function", "secret", "graph", "deployment", "website"]
        },
        "resource_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "enum": ["allow", "deny"]
        },
        "conditions": {
          "type": "string"
        }
      }
    },
    "agent": {
      "type": "object",
      "required": ["id", "name", "can"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "can": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    }
  }
}
