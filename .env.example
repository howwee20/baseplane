ATOLL_CONTROL_PORT=8790
ATOLL_PUBLIC_API_URL=https://api.atolldb.com

# Leave blank for local JSON storage. Set to a Postgres URL for managed/hosted mode.
CONTROL_DATABASE_URL=
CONTROL_DATABASE_SSL=false
NODE_ENV=development
ATOLL_VERSION=local

# Set this in hosted environments. Do not use the example value in production.
SESSION_SECRET=replace-with-a-random-secret

# Comma-separated browser origins allowed to call the hosted API.
CORS_ORIGIN=https://atolldb.com,https://www.atolldb.com,https://howwee20.github.io
